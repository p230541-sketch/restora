# ─────────────────────────────────────────────────────────────────────────────
# VaultSync — PRODUCTION environment template.
# Copy to `.env` on the deploy host (NEVER commit the filled-in file) and run:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# Every value below MUST be overridden from the dev defaults before going live.
# ─────────────────────────────────────────────────────────────────────────────

# Enables the API's fail-closed config checks (refuses to boot on weak secrets).
NODE_ENV=production

# ── Secrets — generate strong, unique values ────────────────────────────────
# JWT signing key:        openssl rand -hex 32
JWT_SECRET=__CHANGE_ME__generate_with_openssl_rand_hex_32
# Postgres password:      openssl rand -base64 24
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password

# ── Database TLS ────────────────────────────────────────────────────────────
# Use "require" (or "verify-full" with a CA) against managed Postgres / RDS.
PG_SSLMODE=require

# ── AWS — real account (remove AWS_ENDPOINT_URL to leave LocalStack) ─────────
# Prefer an IAM role on the compute (ECS task role / instance profile) over
# static keys. If you must use keys, inject them from your secret manager.
AWS_ENDPOINT_URL=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=__from_iam_role_or_secret_manager__
AWS_SECRET_ACCESS_KEY=__from_iam_role_or_secret_manager__

# Verified SES sender for alert emails (must be a verified identity/domain).
ALERT_FROM_EMAIL=alerts@your-domain.com
