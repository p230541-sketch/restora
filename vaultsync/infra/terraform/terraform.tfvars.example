# Copy to terraform.tfvars and fill in. Do NOT commit the filled-in file.
aws_region            = "us-east-1"
project               = "vaultsync"
environment           = "prod"

backup_bucket_name    = "acme-vaultsync-backups-prod" # must be globally unique
backup_retention_days = 30
alert_from_email      = "alerts@your-domain.com"

# RDS telemetry DB
db_instance_class      = "db.t3.micro"
db_allocated_storage   = 20
# db_password is sensitive — pass via env instead of this file:
#   export TF_VAR_db_password="$(openssl rand -base64 24)"

# Networking (from your existing VPC)
vpc_subnet_ids         = ["subnet-aaaa", "subnet-bbbb"]
vpc_security_group_ids = ["sg-xxxx"]

tags = {
  Owner = "platform-team"
}
