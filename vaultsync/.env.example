# ── LocalStack / AWS (local) ────────────────────────────────────────────────
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET=vaultsync-backups

# ── SQS ──────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=http://localstack:4566/000000000000/vaultsync-validation

# ── Secrets Manager ──────────────────────────────────────────────────────────
SECRET_ID=vaultsync/aes-key

# ── Edge daemon ──────────────────────────────────────────────────────────────
CRON_SCHEDULE=0 * * * *
NODE_ID=us-east-prod-01
NODE_IP=10.0.42.158
SOURCE_DB_DSN=postgres://vaultsync:secret@source-db:5432/appdb?sslmode=disable
SPOOL_DIR=/var/spool/vaultsyncd
TRIGGER_HTTP_PORT=9100

# ── Telemetry DB (Postgres) ───────────────────────────────────────────────────
TELEMETRY_DB_DSN=postgres://vaultsync:secret@telemetry-db:5432/telemetry?sslmode=disable

# ── Ephemeral DB (Postgres, validation target) ───────────────────────────────
EPHEMERAL_DB_HOST=ephemeral-db
EPHEMERAL_DB_PORT=5432
EPHEMERAL_DB_USER=vaultsync
EPHEMERAL_DB_PASSWORD=secret
EPHEMERAL_DB_ADMIN_DSN=postgres://vaultsync:secret@ephemeral-db:5432/postgres?sslmode=disable

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001

# ── Security (Phase 2/3 hardening) ────────────────────────────────────────────
# REQUIRED in production. Generate with `openssl rand -hex 32`.
# The API refuses to start when NODE_ENV=production and this is unset or default.
JWT_SECRET=vaultsync-dev-secret-change-me
# Set to "production" to enforce the JWT_SECRET check above.
NODE_ENV=development

# ── Alerting (SES) ────────────────────────────────────────────────────────────
# Verified SES sender for outbound alert emails. Recipient is set in
# Settings → Notifications (alert_email). For real AWS, verify these identities.
ALERT_FROM_EMAIL=alerts@vaultsync.io
